-- 7. ระบบหน้าเมนู (Pages)
local pages = {}
local function createPage(name)
    local page = Instance.new("ScrollingFrame", contentFrame)
    page.Name = name.."Page"
    page.Size = UDim2.new(1, 0, 1, 0)
    page.BackgroundTransparency = 1
    page.Visible = false
    page.CanvasSize = UDim2.new(0, 0, 0, 500)
    page.ScrollBarThickness = 3
    local layout = Instance.new("UIListLayout", page)
    layout.Padding = UDim.new(0, 8)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    pages[name] = page
    return page
end

local function showPage(name)
    for _, p in pairs(pages) do p.Visible = false end
    if pages[name] then pages[name].Visible = true end
end

local homePage = createPage("Home")
local spawnPage = createPage("Spawn")
local killPage = createPage("Kill")
local creditPage = createPage("Credit")

-- 8. ฟังก์ชันสร้างปุ่มเมนูซ้าย
local function addNavBtn(name, pos)
    local btn = Instance.new("TextButton", leftNav)
    btn.Size = UDim2.new(0.9, 0, 0, 40)
    btn.Position = UDim2.new(0.05, 0, 0, 50 + (pos * 45))
    btn.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
    btn.Text = name
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", btn)
    btn.MouseButton1Click:Connect(function() showPage(name) end)
end

addNavBtn("Home", 0)
addNavBtn("Spawn", 1)
addNavBtn("Kill", 2)
addNavBtn("Credit", 3)

-- 9. ระบบสีรุ้ง
task.spawn(function()
    local h = 0
    while true do
        h = h + (1/300)
        local color = Color3.fromHSV(h, 0.8, 1)
        mainStroke.Color = color
        openStroke.Color = color
        titleBar.TextColor3 = color
        task.wait()
    end
end)

-- 10. ระบบลากหน้าจอ
local dragging, dragStart, startPos
titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true dragStart = input.Position startPos = mainFrame.Position
    end
end)
UIS.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UIS.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end end)

-- 11. ระบบพับ/ปิด
minBtn.MouseButton1Click:Connect(function()
    mainFrame.Visible = false
    openBtn.Visible = true
end)

openBtn.MouseButton1Click:Connect(function()
    mainFrame.Visible = true
    openBtn.Visible = false
end)

closeBtn.MouseButton1Click:Connect(function() screen:Destroy() end)

-- 🛠️ ฟังก์ชันสร้างปุ่ม Spawn (อ้างอิงตามสคริปต์ที่น้องให้มา)
local function createSpawnButton(name, type)
    local btn = Instance.new("TextButton", spawnPage)
    btn.Size = UDim2.new(0.9, 0, 0, 45)
    btn.Text = name
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", btn)

    local active = false
    btn.MouseButton1Click:Connect(function()
        if type == "detonate_tnt" then
            btn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
            pcall(function()
                for _, obj in pairs(workspace:GetChildren()) do
                    if obj.Name == "tnt" and obj:FindFirstChild("Part") then
                        task.spawn(function() RS.toggle:FireServer(obj.Part) end)
                    end
                end
            end)
            task.wait(0.2)
            btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        else
            active = not active
            btn.Text = active and name.." [ON]" or name
            btn.BackgroundColor3 = active and Color3.fromRGB(0, 80, 0) or Color3.fromRGB(40, 40, 40)
            
            task.spawn(function()
                while active do
                    pcall(function()
                        local char = player.Character
                        local lockPos = char.HumanoidRootPart.Position + (char.HumanoidRootPart.CFrame.LookVector * 5)
                        local spawnRemote = RS.sandboxconnection.spawnobject
                        
                        if type == "spawn_tnt" then
                            local args = {RS.items.tnt, {color = Color3.new(1,1,1), ammo="", grade=0, fluids={{name="", value=""}}}}
                            for i=1, 10 do task.spawn(function() 
                                local obj = spawnRemote:InvokeServer(unpack(args))
                                if obj and obj:FindFirstChild("Part") then obj.Part.CFrame = CFrame.new(lockPos) end
                            end) end
                        elseif type == "Chicken" then
                            local args = {RS.items.Chicken, {color = Color3.new(1,1,1), ammo="", grade=0, fluids={{name="", value=""}}}}
                            for i=1, 15 do task.spawn(function() 
                                local obj = spawnRemote:InvokeServer(unpack(args))
                                if obj and obj:FindFirstChild("Part") then obj.Part.CFrame = CFrame.new(lockPos) end
                            end) end
                        elseif type == "Zombie" then
                            for i=1, 15 do task.spawn(function() 
                                local obj = RS.sandboxconnection.spawnzombie:InvokeServer()
                                if obj and obj:FindFirstChild("HumanoidRootPart") then obj.HumanoidRootPart.CFrame = CFrame.new(lockPos) end
                            end) end
                        end
                    end)
                    task.wait(0.1)
                end
            end)
        end
    end)
end

-- ใส่ปุ่มหน้า Spawn
createSpawnButton("📦 SPAWN TNT (2X)", "spawn_tnt")
createSpawnButton("💥 BOOM (SINGLE CLICK)", "detonate_tnt")
createSpawnButton("🐥 CHICKEN (3X)", "Chicken")
createSpawnButton("🧟 ZOMBIE (3X)", "Zombie")

-- --- KILL PAGE ---
local damRemote = RS:WaitForChild("dam")
local function addKillBtn(name, loopMode, isNpc)
    local btn = Instance.new("TextButton", killPage)
    btn.Size = UDim2.new(0.9, 0, 0, 40)
    btn.Text = name
    btn.BackgroundColor3 = Color3.fromRGB(60, 20, 20)
    btn.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", btn)

    local active = false
    btn.MouseButton1Click:Connect(function()
        if not loopMode then
            -- Kill Once
            local playerChars = {}
            for _, p in ipairs(game.Players:GetPlayers()) do if p.Character then playerChars[p.Character] = true end end
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("Humanoid") and obj.Health > 0 then
                    local isPlayer = playerChars[obj.Parent]
                    if (isNpc and not isPlayer) or (not isNpc and isPlayer and obj.Parent.Name ~= player.Name) then
                        damRemote:FireServer(obj, math.huge)
                    end
                end
            end
        else
            -- Kill Loop
            active = not active
            btn.BackgroundColor3 = active and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(60, 20, 20)
            while active do
                local playerChars = {}
                for _, p in ipairs(game.Players:GetPlayers()) do if p.Character then playerChars[p.Character] = true end end
                for _, obj in ipairs(workspace:GetDescendants()) do
                    if obj:IsA("Humanoid") and obj.Health > 0 then
                        local isPlayer = playerChars[obj.Parent]
                        if (isNpc and not isPlayer) or (not isNpc and isPlayer and obj.Parent.Name ~= player.Name) then
                            damRemote:FireServer(obj, math.huge)
                        end
                    end
                end
                task.wait(0.5)
            end
        end
    end)
end

addKillBtn("💀 Kill All Players", false, false)
addKillBtn("🔄 Kill All Players [LOOP]", true, false)
addKillBtn("👾 Kill All NPCs", false, true)
addKillBtn("🔄 Kill All NPCs [LOOP]", true, true)

-- หน้าแรก
showPage("Home")
